{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A salon service offered at Vietnam Burger Unisex Salon",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the service" },
        "price": { "type": "string", "description": "Price of the service (formatted string)" },
        "description": { "type": "string", "description": "Detailed description of the service" },
        "category": { "type": "string", "enum": ["hair", "grooming", "beauty"], "description": "Service category" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name", "price", "category"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "A portfolio image showcasing the salon's work",
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri", "description": "URL of the image" },
        "alt": { "type": "string", "description": "Alt text for the image" },
        "category": { "type": "string", "description": "Image category (e.g., Hair, Grooming, Interior)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the image was added" }
      },
      "required": ["url", "alt", "category"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the system" },
        "displayName": { "type": "string", "description": "User's display name" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of salon services"
    },
    "/gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Collection of portfolio images"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
